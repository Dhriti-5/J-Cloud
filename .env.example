# Copy this file to .env and replace with your real Neon values.
# .env is gitignored for safety.

# Preferred single URL format (JDBC)
JCLOUD_DB_URL=postgresql://your-neon-host.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Optional split values (used if JCLOUD_DB_URL is empty)
JCLOUD_DB_HOST=your-neon-host.aws.neon.tech
JCLOUD_DB_PORT=5432
JCLOUD_DB_NAME=neondb
JCLOUD_DB_USER=your_neon_user
JCLOUD_DB_PASSWORD=your_neon_password
