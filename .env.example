# Copy this file to .env and replace with your real values.
# .env is gitignored for safety.

# ============ DATABASE CONFIGURATION ============
# Preferred single URL format (JDBC)
JCLOUD_DB_URL=postgresql://your-neon-host.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Optional split values (used if JCLOUD_DB_URL is empty)
JCLOUD_DB_HOST=your-neon-host.aws.neon.tech
JCLOUD_DB_PORT=5432
JCLOUD_DB_NAME=neondb
JCLOUD_DB_USER=your_neon_user
JCLOUD_DB_PASSWORD=your_neon_password

# ============ NETWORK CONFIGURATION ============
# Master Node - set to your master node's Tailscale or real IP
JCLOUD_MASTER_HOST=<your-master-node-ip>
JCLOUD_MASTER_PORT=9000

# Data Node 1 - set to your DataNode1's Tailscale or real IP
JCLOUD_DATANODE1_HOST=<your-datanode1-ip>
JCLOUD_DATANODE1_PORT=9101

# Data Node 2 - set to your DataNode2's Tailscale or real IP
JCLOUD_DATANODE2_HOST=<your-datanode2-ip>
JCLOUD_DATANODE2_PORT=9102

# ============ ADMIN AUTH CONFIGURATION ============
# Admin login used by LoginServlet (do not commit real values)
JCLOUD_ADMIN_USERNAME=<your-admin-username>
JCLOUD_ADMIN_PASSWORD=<your-admin-password>
JCLOUD_ADMIN_EMAIL=<your-admin-email>

# Example for Tailscale setup (replace IPs):
#   JCLOUD_MASTER_HOST=100.89.131.79
#   JCLOUD_DATANODE1_HOST=100.101.47.90
#   JCLOUD_DATANODE2_HOST=100.89.131.79
